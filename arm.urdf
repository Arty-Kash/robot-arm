<?xml version="1.0"?>
<robot name="simple_arm">
  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.1" radius="0.1"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>

  <joint name="joint0" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.04"/></geometry>
      <material name="green"><color rgba="0 1 0 1"/></material>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.5"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="-1.57" upper="1.57" velocity="1.0"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder length="0.4" radius="0.03"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.4"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="-1.57" upper="1.57" velocity="1.0"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry><cylinder length="0.2" radius="0.02"/></geometry>
      <material name="yellow"><color rgba="1 1 0 1"/></material>
    </visual>
  </link>
</robot>